# Bell.qa Qatar MOCI Auto-Scan — schedule + scrape settings
# ---------------------------------------------------------
# After changing any value here, double-click
#   Install Daily Auto-Scan.command
# to apply.

# Day of week to run (mon | tue | wed | thu | fri | sat | sun | daily).
# MOCI is large (~60K active companies) and the site has 503 issues, so
# weekly is the recommended cadence — pick a day when your Mac is on.
day=sun

# When to start the run (24-hour HH:MM, local time).
time=02:00

# Maximum minutes per scheduled run (default 720 = 12 hours).
# The full Active scrape with detail data is expected to take 30-50
# hours total. The scraper resumes automatically — each weekly run does
# a chunk, the next picks up where it left off.
max_run_minutes=720

# -----------------------------------------------------------------------------
# What to scrape
# -----------------------------------------------------------------------------

# Filter: scrape only active companies (active_only=false) or every status
# (active_only=false). MOCI has 213,199 total companies vs 59,871 active;
# active-only is the recommended default to avoid polluting Bell.qa with
# de-registered or expired entries.
active_only=false

# Include the Professional License table (~13K rows) in addition to the
# main Commercial Organizations table.
include_professional_license=true

# Fetch per-company detail data (Trade Name, Company Capital, CR Creation
# Date, Number of Branches, CP Issue Date, Company Type, Municipality,
# Zone, Street, Building, Map URL, Activities). The detail step is
# expensive (one Power BI page navigation per company) but is what
# "complete data" means for Bell.qa. The Diagnose command will help us
# learn if the listing query already includes these fields, in which
# case detail fetching becomes unnecessary.
fetch_details=true

# -----------------------------------------------------------------------------
# Polite pacing between Power BI interactions (seconds).
# Power BI is a cross-origin iframe so we don't control its server's
# rate limits. These delays apply between table-scrolls and between
# detail-page navigations.
scroll_pause=1.0
detail_pause=1.5

# Browser headless mode.
# headless=true   runs invisibly (faster, but MOCI's WAF sometimes detects
#                 headless Chromium and returns 503 to every request).
# headless=false  opens a visible Chrome window on your screen. Much less
#                 likely to be flagged by MOCI's WAF. Use this if you see
#                 "FAILED: tried N rounds" in the log — it almost always
#                 means the WAF is gating the headless browser. The visible
#                 browser does the same work but doesn't get blocked.
#
# Recommended: leave as true; flip to false only if scrapes keep failing.
headless=false

# Manual capture mode: scraper opens browser, you navigate + scroll yourself,
# scraper captures all Power BI traffic. Set to true if automatic scrolling
# isn't working. Press Enter in Terminal when you're done scrolling.
manual=true
