# Bell.qa Qatar QFC Auto-Scan — daily schedule
# --------------------------------------------
# Set the time of day (24-hour clock, HH:MM, local time) that the
# QFC scraper should run automatically.
#
# After you change any value here, double-click
#   Install Daily Auto-Scan.command
# again to apply.

# When to start the daily run.
time=02:00

# Maximum minutes per scheduled run (default 360 = 6 hours).
# A listings-only scan finishes in ~1 minute, so this is mostly a safety
# cap. The scraper resumes automatically if a run somehow hits it.
max_run_minutes=360

# -----------------------------------------------------------------------------
# Polite delay between requests (in seconds).
#
# The QFC site has an Azure Web Application Firewall that returns HTTP 403
# Forbidden if it sees rapid requests from the same IP. The defaults below
# (2.0-4.0s, avg 3s) finish a full scan of ~5,242 companies in roughly
# 4.5 hours — comfortably inside the 6-hour cap. Don't dial these below
# 1.5s unless you want to test your luck with the WAF.
#
# Reference points (5,242 companies + 175 listing pages = 5,417 requests):
#   delay_min=2.0  delay_max=4.0   ->  ~4.5 hours  (default — safe)
#   delay_min=1.5  delay_max=3.5   ->  ~3.7 hours  (faster, slight risk)
#   delay_min=3.0  delay_max=6.0   ->  ~6.8 hours  (paranoid, will span 2 runs)
#
# If you start seeing HTTP 403 in scans/scheduler.log, the WAF is throttling
# you — bump these up.
delay_min=2.0
delay_max=4.0
# -----------------------------------------------------------------------------
# Fetch company detail pages (per-company POST).
#
# Detail-page POSTs (Permitted Activities, Registration Status, Place of
# Incorporation, Legal Status, Directors, Date of Licence, Senior Executive
# Function, Registered Address, etc.) are ON by default. The scraper sends
# the Referer + Origin headers that the QFC server requires to return the
# real detail HTML — without those, the server redirects to qfc.qa's
# homepage (this was the bug in earlier versions and is now fixed).
#
# Set to false if you only want listing-card data (much faster — ~9 min
# total since you skip 5,242 detail POSTs).
fetch_details=true
