# Copy this file to ".env.local" (no .example) and fill in real values.
# .env.local is gitignored and NEVER committed.

# Mapbox token for the home page globe hero.
# - Get a token from https://account.mapbox.com/access-tokens/
# - Restrict it to the URLs "localhost:3000" and "bell.qa" so it can't be abused
# - Public tokens start with "pk." (the secret "sk." token must NEVER be used here)
# - Leave blank to show the static fallback hero instead of the animated globe
NEXT_PUBLIC_MAPBOX_TOKEN=

# Mailtrap (added in Round 5 for the contact form)
# MAILTRAP_API_TOKEN=
# CONTACT_FORM_RECIPIENT=val@bell.qa
